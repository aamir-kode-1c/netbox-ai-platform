# ═══════════════════════════════════════════════════════════════════════════════
# NetBox AI Platform — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Local LLM (Ollama) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=8192

# ─── NetBox ──────────────────────────────────────────────────────────────────
NETBOX_URL=http://netbox.internal:8000
NETBOX_TOKEN=your_netbox_api_token_here
NETBOX_SSL_VERIFY=false
NETBOX_TIMEOUT=30

# ─── PostgreSQL (Agent State DB) ─────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=netbox_ai
POSTGRES_USER=netbox_ai
POSTGRES_PASSWORD=change_me_strong_password

# ─── Redis (Message Bus) ─────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# ─── ChromaDB (Vector Store) ─────────────────────────────────────────────────
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8080
CHROMA_COLLECTION_NETBOX=netbox_schema
CHROMA_PERSIST_DIR=/opt/netbox-ai/chroma

# ─── HPE OpenView / Operations Manager ───────────────────────────────────────
OV_BASE_URL=https://openview.internal:8443
OV_USERNAME=admin
OV_PASSWORD=change_me
OV_SSL_VERIFY=false
OV_API_VERSION=v1

# ─── VMware Aria vROPS ───────────────────────────────────────────────────────
VROPS_HOST=https://vrops.internal
VROPS_USERNAME=admin
VROPS_PASSWORD=change_me
VROPS_SSL_VERIFY=false

# ─── OpenStack ───────────────────────────────────────────────────────────────
OS_AUTH_URL=https://keystone.internal:5000/v3
OS_USERNAME=admin
OS_PASSWORD=change_me
OS_PROJECT_NAME=admin
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_REGION_NAME=RegionOne
OS_CACERT=/etc/ssl/certs/openstack-ca.crt

# ─── OpenShift / Kubernetes ──────────────────────────────────────────────────
KUBECONFIG=/opt/netbox-ai/config/kubeconfig
K8S_NAMESPACE_FILTER=           # empty = all namespaces
K8S_VERIFY_SSL=false

# ─── HPE 3PAR / Primera ──────────────────────────────────────────────────────
TPAR_HOST=https://3par.internal:8080
TPAR_USERNAME=3paradm
TPAR_PASSWORD=change_me
TPAR_SSL_VERIFY=false
TPAR_WSAPI_VERSION=1.7

# ─── Agent Scheduling ────────────────────────────────────────────────────────
AGENT1_FULL_INTERVAL_MIN=30
AGENT1_INCREMENTAL_INTERVAL_MIN=5
AGENT5_POLL_INTERVAL_MIN=5
AGENT6_SCAN_INTERVAL_MIN=60

# ─── Lifecycle Rules ─────────────────────────────────────────────────────────
LIFECYCLE_VM_GRACE_DAYS=7
LIFECYCLE_SERVER_GRACE_DAYS=30
LIFECYCLE_POD_GRACE_DAYS=1

# ─── Chatbox UI ──────────────────────────────────────────────────────────────
CHATBOX_PORT=8501
CHATBOX_TITLE=NetBox AI Assistant
CHATBOX_MAX_HISTORY=10

# ─── Platform ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=/var/log/netbox-ai
DATA_DIR=/opt/netbox-ai/data
PLATFORM_ENV=production
